{
	"root": false,
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"files": {
		"includes": [
			"src/**/*.ts",
			"src/**/*.js",
			"src/**/*.mjs",
			"src/**/*.json",
			"src/**/*.jsonc",
			"!src/i18n-types.ts",
			"!src/i18n-util.ts",
			"!src/i18n-util.*.ts"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"complexity": {
				"noBannedTypes": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noConsole": { "level": "error", "options": { "allow": ["warn", "error"] } },
				"noEmptyBlockStatements": "error"
			},
			"nursery": {
				"noFloatingPromises": "warn"
			}
		}
	}
}
