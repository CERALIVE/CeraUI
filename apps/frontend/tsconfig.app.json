{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "types": ["vitest/globals"],
    "useDefineForClassFields": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    // exactOptionalPropertyTypes is intentionally NOT enabled here: it is
    // incompatible with the bits-ui v2 / shadcn-svelte UI layer, which emits
    // unfixable "union type too complex to represent" errors on its own prop
    // spreads in CLI-managed components. It IS enabled in every other tsconfig
    // (root, backend, rpc, node, e2e). See AGENTS.md "Linting".
    "noImplicitOverride": true,
    // Enhanced source map configuration for better debugging
    "sourceMap": true,
    "inlineSourceMap": false,
    "inlineSources": false,
    "sourceRoot": "",
    "mapRoot": "",
    // Enhanced debugging configuration
    "declaration": true,
    "declarationMap": true,
    "preserveSymlinks": true,
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "$main": ["./src/main"],
      "$main/*": ["./src/main/*"]
    }
  },
  "include": ["src", "src/**/*.d.ts", "src/**/*.ts", "src/**/*.js", "src/**/*.svelte"],
  "exclude": ["src/**/*.test.ts"]
}
