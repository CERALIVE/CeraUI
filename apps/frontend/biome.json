{
	"root": false,
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"files": {
		"includes": [
			"package.json",
			"src/**/*.ts",
			"src/**/*.js",
			"src/**/*.json",
			"src/**/*.svelte",
			"vite.config.ts",
			"tailwind.config.ts",
			"pwa.config.ts",
			"svelte.config.js",
			"!**/.svelte-kit/**"
		]
	},
	"javascript": {
		"globals": ["NodeJS", "__APP_VERSION__"]
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noDebugger": "warn",
				"noConsole": { "level": "error", "options": { "allow": ["warn", "error"] } },
				"noEmptyBlockStatements": "error"
			},
			"nursery": {
				"noFloatingPromises": "warn"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.test.ts", "**/*.spec.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noEmptyBlockStatements": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.svelte"],
			"formatter": { "enabled": false },
			"assist": { "actions": { "source": { "organizeImports": "off" } } },
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off",
						"noUnusedFunctionParameters": "off"
					},
					"style": {
						"useImportType": "off",
						"useConst": "off"
					}
				}
			}
		}
	]
}
