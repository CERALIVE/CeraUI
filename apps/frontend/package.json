{
	"name": "frontend",
	"private": true,
	"version": "2026.6.1",
	"description": "A modern UI built with Svelte + Vite for CeraLive streaming hardware.",
	"type": "module",
	"author": "Andrés Cera",
	"license": "GPL-3.0",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"build:federation": "vite build --config vite.federation.config.ts",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json",
		"lint": "echo 'Frontend linting handled by root Biome'",
		"lint:fix": "echo 'Frontend fixing handled by root Biome'",
		"fix": "echo 'Frontend fixing handled by root Biome'",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:install": "playwright install chromium --with-deps",
		"test:e2e:reset": "rm -f ../backend/auth_tokens.json",
		"clean": "rm -rf dist node_modules/.vite"
	},
	"dependencies": {
		"@ceralive/design-tokens": "^2026.6.1",
		"@ceraui/i18n": "workspace:*",
		"@ceraui/rpc": "workspace:*",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource-variable/plus-jakarta-sans": "^5.2.8",
		"@fontsource-variable/space-grotesk": "^5.2.10",
		"@internationalized/date": "^3.12.2",
		"@orpc/client": "^1.14.6",
		"@zip.js/zip.js": "^2.8.26",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"gsap": "^3.15.0",
		"html-to-image": "^1.11.13",
		"mode-watcher": "^1.1.0",
		"qrcode": "^1.5.4",
		"svelte": "^5.56.3",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"typesafe-i18n": "^5.27.1"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@lucide/svelte": "^1.18.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/postcss": "^4.3.1",
		"@tailwindcss/vite": "^4.3.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/svelte": "^5.3.1",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^26.0.1",
		"@types/qrcode": "^1.5.6",
		"jsdom": "^29.1.1",
		"madge": "^8.0.0",
		"svelte-check": "^4.6.0",
		"svelte-persistent-runes": "^2.1.0",
		"tailwindcss": "^4.3.1",
		"tailwindcss-animate": "^1.0.7",
		"ts-node": "^10.9.2",
		"typescript": "catalog:",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.8",
		"workbox-window": "^7.4.1"
	},
	"volta": {
		"node": "24.0.0"
	}
}
