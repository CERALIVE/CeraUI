{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node", "@playwright/test"],
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"noEmit": true
	},
	"include": ["**/*.ts", "../../playwright.config.ts"]
}
