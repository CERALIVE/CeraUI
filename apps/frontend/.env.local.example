# =============================================================================
# CeraUI Frontend — DEV-SYNC power-user mode (Task 14)
# =============================================================================
# Copy to `.env.local` IN THIS DIRECTORY (apps/frontend/) to enable an
# env-gated Vite proxy that points the local dev frontend (with full HMR) at a
# backend running on a REMOTE CERALIVE device.
#
#   cp apps/frontend/.env.local.example apps/frontend/.env.local
#
# .env.local is git-ignored. With NONE of these set, `pnpm dev` is unchanged:
# the frontend talks to the local mock/dev backend exactly as before.
#
# HOW IT WORKS
#   The frontend RPC transport is a single WebSocket opened to the origin root
#   (no /rpc or /ws path). When VITE_DEVICE_HOST is set, Vite proxies that root
#   WebSocket to the device while serving the app + HMR locally. Point the
#   socket at the local Vite origin so it is intercepted by the proxy, e.g.:
#
#     VITE_SOCKET_ENDPOINT=ws://localhost
#     VITE_SOCKET_PORT=6173
#
#   (VITE_SOCKET_* live in the monorepo-root .env — see ../../.env.example.)
# -----------------------------------------------------------------------------

# Remote device hostname or IP. THIS is the activation gate — the proxy block
# is entirely absent unless this is set. (e.g. ceralive.local or 192.168.1.50)
VITE_DEVICE_HOST=ceralive.local

# Device backend port. Optional. Defaults: 80 for ws, 443 for wss.
VITE_DEVICE_PORT=80

# Device transport protocol: ws (plain) or wss (TLS). Optional, default ws.
# With wss the proxy sets secure:false so a device self-signed cert is accepted.
VITE_DEVICE_PROTOCOL=ws
