{
	"root": false,
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"files": {
		"includes": [
			"package.json",
			"src/**/*.ts",
			"src/**/*.js",
			"src/**/*.json",
			"!**/config.json",
			"!**/setup.json",
			"!**/gsm_operator_cache.json"
		]
	},
	"javascript": {
		"globals": ["Bun"]
	},
	"linter": {
		"rules": {
			"correctness": {
				"noUndeclaredVariables": "off"
			},
			"suspicious": {
				"noConsole": { "level": "error", "options": { "allow": ["warn", "error"] } },
				"noEmptyBlockStatements": "error"
			},
			"nursery": {
				"noFloatingPromises": "warn"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.test.ts", "**/*.spec.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noEmptyBlockStatements": "off"
					}
				}
			}
		}
	]
}
