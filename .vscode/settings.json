{
	// ============================================================================
	// MONOREPO WORKSPACE SETTINGS - CeraUI
	// ============================================================================
	// Single toolchain: Biome for TS/JS/JSON and experimental Svelte+TS support.
	// Svelte files are formatted by the Svelte extension and linted by Biome.

	// ============================================================================
	// GLOBAL EDITOR SETTINGS (Linux style, consistent with Biome)
	// ============================================================================
	"editor.formatOnSave": true,
	"editor.formatOnPaste": true,
	"editor.insertSpaces": false,
	"editor.tabSize": 2,
	"editor.detectIndentation": false,
	"editor.rulers": [100],
	"editor.codeActionsOnSave": {
		// Disabled globally - specified per file type to avoid conflicts
	},

	// File settings (Linux LF style - matches Biome)
	"files.eol": "\n",
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,

	// TypeScript global settings
	"typescript.preferences.includePackageJsonAutoImports": "on",
	"typescript.suggest.autoImports": true,
	"typescript.preferences.importModuleSpecifier": "relative",
	"typescript.preferences.importModuleSpecifierEnding": "minimal",
	"javascript.preferences.importModuleSpecifierEnding": "minimal",
	"typescript.workspaceSymbols.scope": "allOpenProjects",

	// ============================================================================
	// BIOME CONFIGURATION (single linter/formatter for the workspace)
	// ============================================================================
	"biome.enabled": true,
	"biome.lsp.bin": "bunx biome",
	"biome.rename": true,
	"biome.requireConfigFile": false,

	// ============================================================================
	// DEFAULT FORMATTERS (file-type based)
	// ============================================================================
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"source.organizeImports.biome": "explicit",
			"source.fixAll.biome": "explicit"
		}
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"source.organizeImports.biome": "explicit",
			"source.fixAll.biome": "explicit"
		}
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"source.fixAll.biome": "explicit"
		}
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"source.fixAll.biome": "explicit"
		}
	},

	// Svelte files: formatted by the Svelte extension, linted by Biome.
	// Biome's experimental HTML formatter is disabled for .svelte in biome.json,
	// so it never reformats markup here.
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},

	// ============================================================================
	// SVELTE FRAMEWORK SETTINGS
	// ============================================================================
	"svelte.enable-ts-plugin": true,
	"svelte.plugin.svelte.compilerWarnings": {
		"a11y-click-events-have-key-events": "ignore"
	},
	"svelte.plugin.svelte.defaultScriptLanguage": "ts",
	"svelte.plugin.typescript.enable": true,
	"svelte.plugin.typescript.diagnostics.enable": true,

	// ============================================================================
	// TAILWIND CSS INTELLISENSE
	// ============================================================================
	"tailwindCSS.includeLanguages": {
		"svelte": "html"
	},
	"tailwindCSS.classAttributes": ["class", "className", "class:list", "classList"],

	// ============================================================================
	// FILE ASSOCIATIONS
	// ============================================================================
	"files.associations": {
		"*.svelte": "svelte"
	},

	// ============================================================================
	// CURSOR/VS CODE OPTIMIZATIONS
	// ============================================================================
	"cursor.cpp.disabledLanguages": [],
	"editor.minimap.enabled": true,
	"workbench.editor.enablePreview": false,

	// ============================================================================
	// WORKSPACE INTEGRATION SETTINGS
	// ============================================================================
	"extensions.experimental.affinity": {
		"svelte.svelte-vscode": 1,
		"biomejs.biome": 1
	},

	// Force extension loading order and isolation
	"svelte.language-server.ls-path": "",
	"svelte.language-server.runtime": "node",
	"svelte.trace.server": "off",
	"search.exclude": {
		"**/node_modules": true,
		"**/dist": true,
		"**/.svelte-kit": true,
		"**/build": true
	},

	// ============================================================================
	// PERFORMANCE & TIMEOUT SETTINGS
	// ============================================================================
	"editor.suggest.showStatusBar": true,
	"editor.hover.delay": 100,
	"editor.quickSuggestionsDelay": 10,
	"typescript.preferences.quoteStyle": "single",
	"typescript.suggest.completeFunctionCalls": true,
	"typescript.updateImportsOnFileMove.enabled": "always",
	"editor.codeActionsOnSaveTimeout": 2000,
	"editor.formatOnSaveTimeout": 2000,

	// Disable conflicting built-in features
	"json.format.enable": false,
	"javascript.format.enable": false,
	"typescript.format.enable": false,
	"html.format.enable": false,

	"biome.files.ignoreUnknown": true,
	"emmet.excludeLanguages": ["svelte"],
	"files.exclude": {
		"**/.biome": true
	}
}
